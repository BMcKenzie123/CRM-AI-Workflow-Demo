# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: incoming webhook URL for Slack or Discord notifications.
# Leave blank to skip notifications (CRM writes still happen).
NOTIFY_WEBHOOK_URL=
NOTIFY_PLATFORM=slack  # slack | discord

# Optional: SQLite database path
CRM_DB_PATH=crm.db

# Optional: log level
LOG_LEVEL=INFO
